# =============================================================================
# macOS Code Signing & Notarization Configuration
# =============================================================================
# This file holds non-sensitive build config only: the public Developer
# ID identity string, the local Keychain profile name, and the public
# Team ID. The actual notarization credentials (Apple ID + app-specific
# password) live in the macOS Keychain via:
#     xcrun notarytool store-credentials "<NOTARIZE_PROFILE>"
# This file is therefore safe to commit and IS committed.
#
# If you fork this project, copy codesign.env.example to codesign.env
# and fill in your own values, then store your notarization credentials
# in your own Keychain with the command above.
#
# Setup guide: see BUILD_MACOS.md → "Code Signing & Notarization"
# =============================================================================

# Developer ID Application certificate name (from Keychain Access).
# Find yours with:  security find-identity -v -p codesigning
CODESIGN_IDENTITY="Developer ID Application: Michael Beijer (L49T4JV667)"

# Keychain profile name for notarytool credentials.
# Created via:  xcrun notarytool store-credentials "supervertaler-notarize"
NOTARIZE_PROFILE="supervertaler-notarize"

# Apple Team ID (visible in your Apple Developer account).
TEAM_ID="L49T4JV667"
